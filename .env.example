# Vercel KV — optional; when set, telemetry cache is shared across all serverless instances
# Get these from: Vercel dashboard → Storage → KV → .env.local
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Supabase — required for auth
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# OpenAI — required for AI predictions and race report emails
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Chat backend — optional; set to enable the AI chatbot feature
NEXT_PUBLIC_FORMULA_CHAT_API_URL=
NEXT_PUBLIC_CHAT_API_BASE=
NEXT_PUBLIC_CHAT_MODE=

# Report email — optional; required to send post-race email reports
REPORT_FROM_EMAIL=
REPORT_TO_EMAILS=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
